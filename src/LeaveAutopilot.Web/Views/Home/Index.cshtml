@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome, @User.Identity?.Name</h1>

    @if (User.IsInRole(Roles.Hr))
    {
        <p>
            You're signed in as <strong>HR</strong>. You can
            <a asp-controller="Hr" asp-action="Employees">manage employees</a> or
            <a asp-controller="Hr" asp-action="ResetPassword">reset a user's password</a>.
        </p>
    }
    else if (User.IsInRole(Roles.Manager))
    {
        <p>You're signed in as a <strong>Manager</strong>.</p>
    }
    else
    {
        <p>You're signed in as an <strong>Employee</strong>.</p>
    }
</div>
