@model LeaveAutopilot.Web.Models.Leave.ApplyLeaveViewModel
@{
    ViewData["Title"] = "Apply for leave";
}

<h1>Apply for leave</h1>
<p>Only working days (Monday-Friday) are counted; weekends are excluded automatically. Requests cannot span across calendar years.</p>

<div class="row">
    <div class="col-md-6">
        <form asp-controller="Leave" asp-action="Apply" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="LeaveType" class="form-label"></label>
                <select asp-for="LeaveType" asp-items="Model.LeaveTypeOptions" class="form-select">
                    <option value="">-- select a leave type --</option>
                </select>
                <span asp-validation-for="LeaveType" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="StartDate" class="form-label"></label>
                <input asp-for="StartDate" type="date" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="StartHalfDay" class="form-check-input" />
                <label asp-for="StartHalfDay" class="form-check-label"></label>
            </div>
            <div class="form-group mb-3">
                <label asp-for="EndDate" class="form-label"></label>
                <input asp-for="EndDate" type="date" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="EndHalfDay" class="form-check-input" />
                <label asp-for="EndHalfDay" class="form-check-label"></label>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Reason" class="form-label"></label>
                <textarea asp-for="Reason" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Reason" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Submit request</button>
            <a asp-controller="Leave" asp-action="Index" class="btn btn-link">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
