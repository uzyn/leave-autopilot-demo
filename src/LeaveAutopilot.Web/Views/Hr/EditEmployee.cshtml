@model LeaveAutopilot.Web.Models.Hr.EditEmployeeViewModel
@{
    ViewData["Title"] = "Edit employee";
}

<h1>Edit employee</h1>

<div class="row">
    <div class="col-md-5">
        <form asp-controller="Hr" asp-action="EditEmployee" asp-route-id="@Model.Id" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Role" class="form-label"></label>
                <select asp-for="Role" asp-items="Model.RoleOptions" class="form-select">
                    <option value="">-- select a role --</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ManagerId" class="form-label"></label>
                <select asp-for="ManagerId" asp-items="Model.ManagerOptions" class="form-select">
                    <option value="">-- no manager --</option>
                </select>
                <span asp-validation-for="ManagerId" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Save changes</button>
            <a asp-controller="Hr" asp-action="Employees" class="btn btn-link">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
